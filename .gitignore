# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Corpus bronze = raw vendor / licensed dumps (invariant 10: bulk data never committed)
corpus/bronze/*
!corpus/bronze/.gitkeep

# Silver = normalized corpus DERIVED from GORILA (lineara.xyz has no open license) -> gitignored
corpus/silver/*.json
corpus/silver/*.jsonl
!corpus/silver/.gitkeep

# Generated analytical stores (single-writer; rebuild from silver)
corpus/gold/*.duckdb
corpus/gold/*.parquet
*.duckdb
*.duckdb.wal
data/

# Runtime / reports / editor cruft
runtime/
reports/
.DS_Store
*.swp
.idea/
.vscode/
